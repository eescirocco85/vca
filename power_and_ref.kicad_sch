			)
			(justify left top)
		)
		(uuid "5d6329d2-0e82-42c5-9059-bbb1fe2ac333")
	)
	(text_box "Volume control to LM13700 is current based and the input has an offset of 2 Si diode drops, so there is a biased pair of diodes as the opamp reference. There is also a 1M resistor which can be tweaked to make sure Iabc does not go to exactly 0 uA or negative."
		(exclude_from_sim no)
		(at 115.57 64.77 0)
		(size 34.29 20.32)
		(margins 0.9525 0.9525 0.9525 0.9525)
